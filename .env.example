# 이 파일은 환경변수 키 목록만 공유한다.
# 실제 값은 `.env`에 채우고, `.env`는 git에 커밋하지 않는다.

# --- PostgreSQL (docker-compose) ---
POSTGRES_DB=gym
POSTGRES_USER=gym
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# --- Backend ---
DATABASE_URL=postgres://gym:change-me@localhost:5432/gym?sslmode=disable
# 테스트 DB (운영/개발과 격리. 같은 컨테이너에 별도 데이터베이스로 둔다)
TEST_DATABASE_URL=postgres://gym:change-me@localhost:5432/gym_test?sslmode=disable
# JWT 비밀키 — access/refresh 분리. 각각 32바이트 이상 랜덤(예: openssl rand -base64 48)
JWT_ACCESS_SECRET=change-me-access-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars
PORT=8080
CORS_ORIGIN=http://localhost:5173
# dev | prod (prod에서는 HTTPS 강제 + HSTS)
APP_ENV=dev

# --- Seed admin (시드 SQL 적용 시 1회 사용 후 셸 변수 제거 권장) ---
# 시드 SQL에는 bcrypt 해시만 들어간다. 평문은 SQL 파일·로그에 남기지 않는다.
SEED_ADMIN_USERNAME=owner
SEED_ADMIN_PASSWORD=change-me-on-first-login
SEED_ADMIN_PASSWORD_HASH=

# --- Seed branch (최초 1개 지점) ---
# 공백 포함 값은 반드시 큰따옴표로 감싼다(셸 파싱 오류 방지: `set -a; source .env`).
SEED_BRANCH_NAME="PBOY MMA 본점"
SEED_BRANCH_ADDRESS="서울 송파구 가락로 142 지하 1층"

# --- Frontend ---
VITE_API_URL=http://localhost:8080
